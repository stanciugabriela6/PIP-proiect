<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" fillWidth="false" prefHeight="700.0" prefWidth="650.0" spacing="15.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proiectpip2.RegisterController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <Label fx:id="titleLabel" text="Register">
            <font>
                <Font size="36.0" />
            </font>
        </Label>

        <Label prefHeight="18.0" prefWidth="349.0" text="Username" />
        <TextField fx:id="usernameField" prefWidth="350.0" />

        <Label prefHeight="18.0" prefWidth="352.0" text="Email" />
        <TextField fx:id="emailField" prefWidth="350.0" />

        <Label prefHeight="18.0" prefWidth="354.0" text="Password" />
        <PasswordField fx:id="passwordField" prefWidth="350.0" />

        <Label prefHeight="18.0" prefWidth="350.0" text="Confirm Password" />
        <PasswordField fx:id="confirmPasswordField" prefWidth="350.0" />

        <Label prefHeight="18.0" prefWidth="344.0" text="Role" />
        <ComboBox fx:id="roleComboBox" prefHeight="23.0" prefWidth="338.0" />

        <Button fx:id="registerButton" mnemonicParsing="false" onAction="#handleRegister" prefHeight="50.0" prefWidth="200.0" text="Register">
            <font>
                <Font size="24.0" />
            </font>
        </Button>
        <Label text="OR">
            <font>
                <Font size="36.0" />
            </font>
        </Label>
        <Button mnemonicParsing="false" onAction="#handleGoToRegisterId" prefHeight="50.0" prefWidth="200.0" text="Register your face" />

        <Label />
        <Label text="Already have an account?" />

        <Button fx:id="loginRegister" mnemonicParsing="false" onAction="#handleGoToLogin" prefWidth="140.0" text="Login" />

        <Label fx:id="messageLabel" alignment="CENTER" prefWidth="250.0" />
    </children>
</VBox>