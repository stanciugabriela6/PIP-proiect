<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="730.0" prefWidth="777.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proiectpip2.RegisterController">
   <children>
      <VBox alignment="CENTER" layoutX="67.0" layoutY="18.0" prefHeight="694.0" prefWidth="607.0" spacing="15.0">
         <children>
            <Label fx:id="titleLabel" prefHeight="54.0" prefWidth="204.0" text="Register">
               <font>
                  <Font name="System Bold" size="36.0" />
               </font>
            </Label>
            <Label prefHeight="18.0" prefWidth="113.0" text="Username" />
            <TextField fx:id="usernameField" prefWidth="350.0" />
            <Label prefHeight="18.0" prefWidth="71.0" text="Email" />
            <TextField fx:id="emailField" prefWidth="350.0" />
            <Label prefHeight="18.0" prefWidth="64.0" text="Password" />
            <PasswordField fx:id="confirmPasswordField" prefWidth="350.0" />
            <Label prefHeight="18.0" prefWidth="121.0" text=" Confirm Password" />
            <PasswordField fx:id="passwordField" prefWidth="350.0" />
            <Label prefHeight="18.0" prefWidth="107.0" text="Role" />
            <ComboBox fx:id="roleComboBox" prefHeight="52.0" prefWidth="195.0" />
            <Button fx:id="registerButton" mnemonicParsing="false" onAction="#handleRegister" prefHeight="30.0" prefWidth="250.0" text="Register">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Label prefHeight="18.0" prefWidth="135.0" text="Already have an account?" />
            <Button fx:id="loginRegister" mnemonicParsing="false" onAction="#handleGoToLogin" prefWidth="140.0" text="Login" />
            <Label fx:id="messageLabel" prefHeight="18.0" prefWidth="266.0" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
